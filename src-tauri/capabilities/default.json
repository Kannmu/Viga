{
  "identifier": "default",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read",
    "fs:allow-write",
    {
      "identifier": "http:default",
      "allow": [
        "https://*",
        "http://*"
      ]
    },
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:default"
  ]
}
